// ============================================================================
// Aqua DB Copilot — Enterprise PostgreSQL Schema
// Banking-grade database schema with proper types, constraints, and indexes
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["aqua_db"]
}

// ============================================================
// CORE: Projects & Workspace
// ============================================================

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  description String?  @db.Text
  dialect     String   @db.VarChar(30) // postgresql | mysql | oracle | sqlserver | snowflake | bigquery | mongodb | mariadb
  status      String   @default("active") @db.VarChar(20)
  schemas     String?  @db.Text // JSON array of schema names, e.g. ["public", "auth", "billing"]
  dbSchema    String?  @db.VarChar(63) // PostgreSQL schema name for this project (e.g. proj_a1b2c3d4)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  files              ProjectFile[]
  schemaSnapshots    SchemaSnapshot[]
  tables             TableMetadata[]
  savedQueries       SavedQuery[]
  queryExecutions    QueryExecution[]
  performanceRuns    PerformanceRun[]
  migrations         Migration[]
  dataLifecycleRules DataLifecycleRule[]
  aiConversations    AIConversation[]
  dbConnections      DatabaseConnection[]
  auditLogs          AuditLog[]
  columnMappings     ColumnMappingConfig[]
  dataSheetMappings  DataSheetMappingConfig[]
  savedDiagrams      SavedDiagram[]
  aiUsageLogs        AIUsageLog[]
  aiBudget           AIBudgetConfig?
  drAssessments      DRAssessment[]
  costAssessments    CostAssessment[]

  @@schema("aqua_db")
  @@index([status])
  @@index([createdAt])
}

model ProjectFile {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @db.Uuid
  fileName   String   @db.VarChar(500)
  filePath   String   @db.VarChar(1000)
  fileType   String   @db.VarChar(50)
  fileSize   Int
  dialect    String?  @db.VarChar(30)
  checksum   String   @db.VarChar(128)
  uploadedAt DateTime @default(now()) @db.Timestamptz

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parseResult FileParseResult?

  @@schema("aqua_db")
  @@index([projectId])
  @@index([fileType])
}

model FileParseResult {
  id             String    @id @default(uuid()) @db.Uuid
  fileId         String    @unique @db.Uuid
  status         String    @default("pending") @db.VarChar(20)
  statementCount Int       @default(0)
  tableCount     Int       @default(0)
  errorCount     Int       @default(0)
  errors         String?   @db.Text
  parsedAt       DateTime? @db.Timestamptz
  duration       Int?      // milliseconds

  file ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
}

// ============================================================
// SCHEMA INTELLIGENCE
// ============================================================

model SchemaSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  version      Int
  label        String?  @db.VarChar(200)
  snapshotData String   @db.Text // JSON: full schema snapshot
  createdAt    DateTime @default(now()) @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

model TableMetadata {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @db.Uuid
  schemaName    String   @default("public") @db.VarChar(128)
  tableName     String   @db.VarChar(256)
  tableType     String   @default("table") @db.VarChar(30)
  description   String?  @db.Text
  estimatedRows BigInt?
  originalDDL   String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns     ColumnMetadata[]
  indexes     IndexMetadata[]
  constraints ConstraintMetadata[]
  triggers    TriggerMetadata[]

  outgoingRelationships RelationshipMetadata[] @relation("SourceTable")
  incomingRelationships RelationshipMetadata[] @relation("TargetTable")

  @@schema("aqua_db")
  @@unique([projectId, schemaName, tableName])
  @@index([projectId])
}

model ColumnMetadata {
  id                 String  @id @default(uuid()) @db.Uuid
  tableId            String  @db.Uuid
  columnName         String  @db.VarChar(256)
  dataType           String  @db.VarChar(100)
  normalizedType     String? @db.VarChar(100)
  ordinalPosition    Int
  isNullable         Boolean @default(true)
  isPrimaryKey       Boolean @default(false)
  isUnique           Boolean @default(false)
  defaultValue       String? @db.Text
  characterMaxLength Int?
  numericPrecision   Int?
  numericScale       Int?
  description        String? @db.Text
  sensitivityTag     String? @db.VarChar(30) // PII | PHI | Financial | Public | Internal

  table TableMetadata @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@unique([tableId, columnName])
  @@index([tableId, ordinalPosition])
}

model IndexMetadata {
  id          String  @id @default(uuid()) @db.Uuid
  tableId     String  @db.Uuid
  indexName   String  @db.VarChar(256)
  indexType   String  @db.VarChar(30)
  isUnique    Boolean @default(false)
  isPrimary   Boolean @default(false)
  columns     String  @db.Text // JSON: column names
  originalDDL String? @db.Text

  table TableMetadata @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@unique([tableId, indexName])
}

model ConstraintMetadata {
  id             String  @id @default(uuid()) @db.Uuid
  tableId        String  @db.Uuid
  constraintName String  @db.VarChar(256)
  constraintType String  @db.VarChar(30) // PRIMARY_KEY | FOREIGN_KEY | UNIQUE | CHECK | NOT_NULL
  definition     String? @db.Text
  columns        String  @db.Text // JSON: column names

  table TableMetadata @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@unique([tableId, constraintName])
}

model RelationshipMetadata {
  id               String  @id @default(uuid()) @db.Uuid
  sourceTableId    String  @db.Uuid
  targetTableId    String  @db.Uuid
  relationshipType String  @db.VarChar(30) // one-to-one | one-to-many | many-to-many
  sourceColumns    String  @db.Text
  targetColumns    String  @db.Text
  constraintName   String? @db.VarChar(256)
  isInferred       Boolean @default(false)
  onDelete         String? @db.VarChar(30)
  onUpdate         String? @db.VarChar(30)

  sourceTable TableMetadata @relation("SourceTable", fields: [sourceTableId], references: [id], onDelete: Cascade)
  targetTable TableMetadata @relation("TargetTable", fields: [targetTableId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([sourceTableId])
  @@index([targetTableId])
}

model TriggerMetadata {
  id          String   @id @default(uuid()) @db.Uuid
  tableId     String   @db.Uuid
  triggerName String   @db.VarChar(256)
  timing      String   @db.VarChar(20) // BEFORE | AFTER | INSTEAD OF
  event       String   @db.VarChar(20) // INSERT | UPDATE | DELETE
  triggerBody String   @db.Text
  isEnabled   Boolean  @default(true)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  table TableMetadata @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@unique([tableId, triggerName])
  @@index([tableId])
}

// ============================================================
// QUERY INTELLIGENCE
// ============================================================

model SavedQuery {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  title       String   @db.VarChar(500)
  description String?  @db.Text
  sql         String   @db.Text
  dialect     String   @db.VarChar(30)
  category    String?  @db.VarChar(50)
  isFavorite  Boolean  @default(false)
  tags        String?  @db.Text // JSON array of tags
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions QueryExecution[]

  @@schema("aqua_db")
  @@index([projectId])
  @@index([projectId, isFavorite])
}

model QueryExecution {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @db.Uuid
  savedQueryId  String?  @db.Uuid
  sql           String   @db.Text
  dialect       String   @db.VarChar(30)
  status        String   @db.VarChar(20) // success | error | cancelled
  rowsAffected  Int?
  rowsReturned  Int?
  executionTime Int?     // milliseconds
  resultPreview String?  @db.Text // JSON: first N rows
  explainPlan   String?  @db.Text
  errorMessage  String?  @db.Text
  executedAt    DateTime @default(now()) @db.Timestamptz

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  savedQuery SavedQuery? @relation(fields: [savedQueryId], references: [id], onDelete: SetNull)

  @@schema("aqua_db")
  @@index([projectId, executedAt])
}

// ============================================================
// PERFORMANCE LAB
// ============================================================

model PerformanceRun {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @db.Uuid
  runType         String    @db.VarChar(50)
  status          String    @db.VarChar(20)
  summary         String?   @db.Text
  findings        String?   @db.Text // JSON
  recommendations String?   @db.Text // JSON
  startedAt       DateTime  @default(now()) @db.Timestamptz
  completedAt     DateTime? @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([projectId, startedAt])
}

// ============================================================
// MIGRATION STUDIO
// ============================================================

model Migration {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  version       String    @db.VarChar(50)
  title         String    @db.VarChar(500)
  description   String?   @db.Text
  upSQL         String    @db.Text
  downSQL       String?   @db.Text
  status        String    @default("draft") @db.VarChar(20) // draft | pending | applied | failed | rolled_back
  appliedAt     DateTime? @db.Timestamptz
  sourceDialect String    @db.VarChar(30)
  targetDialect String    @db.VarChar(30)
  checksum      String    @db.VarChar(128)
  dependsOn     String?   @db.Text // JSON: array of version strings
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@unique([projectId, version])
  @@index([projectId, status])
}

model ColumnMappingConfig {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  name            String   @db.VarChar(200)
  sourceTableName String   @db.VarChar(256)
  targetTableName String   @db.VarChar(256)
  sourceDialect   String   @db.VarChar(30)
  targetDialect   String   @db.VarChar(30)
  mappings        String   @db.Text // JSON: column mapping config
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([projectId])
}

model DataSheetMappingConfig {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  name            String   @db.VarChar(200)
  sourceTableName String   @db.VarChar(256)
  csvFileName     String   @db.VarChar(500)
  mappings        String   @db.Text // JSON: DataSheetMapping[]
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([projectId])
}

// ============================================================
// DIAGRAM STUDIO
// ============================================================

model SavedDiagram {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  name            String   @db.VarChar(200)
  description     String?  @db.Text
  diagramType     String   @db.VarChar(30) // er-full | er-compact | dependency-graph | schema-group
  includedTables  String?  @db.Text // JSON: string[] of table IDs (null = all)
  nodePositions   String?  @db.Text // JSON: Record<string, {x,y}>
  layoutDirection String   @default("TB") @db.VarChar(5) // TB | LR
  showColumns     Boolean  @default(true)
  showLabels      Boolean  @default(true)
  colorBySchema   Boolean  @default(false)
  annotations     String?  @db.Text // JSON: Array<{id,x,y,text,color}>
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([projectId])
}

// ============================================================
// DATA LIFECYCLE MANAGEMENT
// ============================================================

model DataLifecycleRule {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @db.Uuid
  ruleName      String   @db.VarChar(200)
  ruleType      String   @db.VarChar(30) // retention | archive | masking | deletion
  targetTable   String   @db.VarChar(256)
  targetColumns String?  @db.Text // JSON: column names
  configuration String   @db.Text // JSON: rule config
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([projectId, ruleType])
  @@index([isActive])
}

// ============================================================
// AI CONVERSATIONS
// ============================================================

model AIConversation {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  title     String   @db.VarChar(500)
  context   String   @db.VarChar(50) // schema | query | performance | migration | lifecycle
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@schema("aqua_db")
  @@index([projectId, context])
}

model AIMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  role           String   @db.VarChar(20) // user | assistant | system
  content        String   @db.Text
  metadata       String?  @db.Text // JSON: token usage, model info, etc.
  createdAt      DateTime @default(now()) @db.Timestamptz

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([conversationId, createdAt])
}

// ============================================================
// DATABASE CONNECTIONS
// ============================================================

model DatabaseConnection {
  id                String    @id @default(uuid()) @db.Uuid
  projectId         String    @db.Uuid
  name              String    @db.VarChar(200)
  dialect           String    @db.VarChar(30)
  host              String    @db.VarChar(500)
  port              Int
  database          String    @db.VarChar(200)
  username          String    @db.VarChar(200)
  passwordEncrypted String    @db.Text
  sslEnabled        Boolean   @default(false)
  sslConfig         String?   @db.Text // JSON: SSL cert paths
  isActive          Boolean   @default(true)
  lastTestedAt      DateTime? @db.Timestamptz
  createdAt         DateTime  @default(now()) @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([projectId])
}

// ============================================================
// SETTINGS & SECURITY
// ============================================================

model AppSettings {
  id    String @id @default("singleton") @db.VarChar(50)
  key   String @unique @db.VarChar(200)
  value String @db.Text

  @@schema("aqua_db")
}

model AIProviderConfig {
  id              String   @id @default(uuid()) @db.Uuid
  provider        String   @db.VarChar(30) // anthropic | openai | gemini | openrouter | ollama
  apiKeyEncrypted String?  @db.Text
  baseUrl         String?  @db.VarChar(500)
  model           String   @db.VarChar(100)
  isDefault       Boolean  @default(false)
  isEnabled       Boolean  @default(true)
  maxTokens       Int      @default(4096)
  temperature     Float    @default(0.3)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  @@schema("aqua_db")
  @@unique([provider, model])
  @@index([isEnabled, isDefault])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String?  @db.Uuid
  action    String   @db.VarChar(50) // CREATE | UPDATE | DELETE | EXECUTE | LOGIN | EXPORT
  entity    String   @db.VarChar(100) // table name or entity type
  entityId  String?  @db.Uuid
  details   String?  @db.Text // JSON: action details
  ipAddress String?  @db.VarChar(45) // IPv4 or IPv6
  userAgent String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @db.Timestamptz

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@schema("aqua_db")
  @@index([projectId, createdAt])
  @@index([action, createdAt])
  @@index([entityId])
}

// ============================================================
// AI OBSERVABILITY & TOKEN GOVERNANCE
// ============================================================

model AIUsageLog {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String?  @db.Uuid
  module        String   @db.VarChar(30)   // schema | query | performance | datagen | docs | migration | chat
  endpoint      String   @db.VarChar(100)  // e.g. /ai/schema/suggest
  provider      String   @db.VarChar(30)   // anthropic | openai | ollama
  model         String   @db.VarChar(100)  // claude-sonnet-4-20250514 etc.
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  estimatedCost Float    @default(0)       // USD
  durationMs    Int      @default(0)
  status        String   @db.VarChar(20)   // success | error
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@schema("aqua_db")
  @@index([projectId, createdAt])
  @@index([module, createdAt])
  @@index([provider, model, createdAt])
  @@index([createdAt])
}

model AIBudgetConfig {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String?  @unique @db.Uuid // null = global budget
  monthlyTokenLimit BigInt
  warningThreshold  Float    @default(0.8)  // 80%
  isHardLimit       Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([isActive])
}

// ============================================================
// DISASTER RECOVERY
// ============================================================

model DRAssessment {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @db.Uuid
  name              String   @db.VarChar(200)
  infrastructure    String   @db.Text  // JSON: provider, regions, dbEngine, dbVersion, dbSizeGB, tableCount, avgTPS, peakTPS, haEnabled, clusterType
  backupConfig      String   @db.Text  // JSON: strategy, fullBackupFreq, incrBackupFreq, retentionDays, backupLocation, backupEncrypted, lastBackupTest
  replicationConfig String   @db.Text  // JSON: type, topology, replicaCount, replicaRegions, lagToleranceSec, autoFailover
  compliance        String   @db.Text  // JSON: industry, regulations[], targetRTO_min, targetRPO_min, dataClassification, drTestFrequency
  strategy          String?  @db.Text  // JSON: full AI-generated DR strategy
  riskScore         Int?               // 0-100 computed risk score
  status            String   @default("draft") @db.VarChar(20) // draft | analyzed | approved | archived
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([projectId, status])
  @@index([createdAt])
}

// ============================================================
// DATABASE COST OPTIMIZATION
// ============================================================

model CostAssessment {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  name            String   @db.VarChar(200)
  cloudConfig     String   @db.Text  // JSON: provider, service, instanceType, region, monthlyCost, storageGB, computeHours, reservedInstances
  queryPatterns   String   @db.Text  // JSON: topQueries[], avgQueryCost, fullTableScans, queryVolume, peakHours
  storageProfile  String   @db.Text  // JSON: totalStorageGB, dataGrowthRate, unusedTables, largestTables, archiveCandidates
  indexProfile    String   @db.Text  // JSON: totalIndexes, unusedIndexes, duplicateIndexes, missingIndexes, indexSizeGB
  analysis        String?  @db.Text  // JSON: full AI-generated cost analysis
  monthlySavings  Float?             // estimated monthly $ savings
  status          String   @default("draft") @db.VarChar(20) // draft | analyzed | implemented | archived
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([projectId, status])
  @@index([createdAt])
}

// ============================================================
// PERFORMANCE TESTING SUITE (PT Suite)
// ============================================================

model PtApiCollection {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(300)
  description String?  @db.Text
  baseUrl     String   @db.VarChar(1000)
  swaggerSpec String?  @db.Text  // JSON: raw parsed OpenAPI spec
  authConfig  String?  @db.Text  // JSON: {type, token, apiKey, basicAuth, etc.}
  headers     String?  @db.Text  // JSON: default headers [{key, value}]
  variables   String?  @db.Text  // JSON: environment variables [{key, value, env}]
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  endpoints PtApiEndpoint[]
  chains    PtApiChain[]

  @@schema("aqua_db")
  @@index([createdAt])
}

model PtApiEndpoint {
  id           String  @id @default(uuid()) @db.Uuid
  collectionId String  @db.Uuid
  name         String  @db.VarChar(300)
  method       String  @db.VarChar(10)  // GET | POST | PUT | PATCH | DELETE
  path         String  @db.VarChar(1000)
  description  String? @db.Text
  headers      String? @db.Text  // JSON: [{key, value}]
  queryParams  String? @db.Text  // JSON: [{key, value, enabled}]
  bodyType     String? @db.VarChar(30) // json | form | xml | none
  bodyTemplate String? @db.Text  // JSON template with {{variables}}
  tags         String? @db.Text  // JSON: string[]
  createdAt    DateTime @default(now()) @db.Timestamptz

  collection PtApiCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  chainSteps PtChainStep[]

  @@schema("aqua_db")
  @@index([collectionId])
}

model PtApiChain {
  id           String   @id @default(uuid()) @db.Uuid
  collectionId String   @db.Uuid
  name         String   @db.VarChar(300)
  description  String?  @db.Text
  isDemo       Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  collection PtApiCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  steps      PtChainStep[]
  scenarios  PtLoadScenario[]

  @@schema("aqua_db")
  @@index([collectionId])
}

model PtChainStep {
  id           String  @id @default(uuid()) @db.Uuid
  chainId      String  @db.Uuid
  endpointId   String? @db.Uuid
  sortOrder    Int
  name         String  @db.VarChar(300)
  method       String  @db.VarChar(10)
  url          String  @db.VarChar(1000) // Can contain {{variables}}
  headers      String? @db.Text  // JSON: [{key, value}]
  body         String? @db.Text  // JSON body with {{variables}}
  extractors   String? @db.Text  // JSON: [{name, source, path}] — JSONPath/regex extractors
  assertions   String? @db.Text  // JSON: [{type, target, operator, value}]
  preScript    String? @db.Text  // JavaScript pre-request script
  postScript   String? @db.Text  // JavaScript post-response script
  thinkTimeSec Float   @default(0) // Delay after step
  isEnabled    Boolean @default(true)

  chain    PtApiChain     @relation(fields: [chainId], references: [id], onDelete: Cascade)
  endpoint PtApiEndpoint? @relation(fields: [endpointId], references: [id], onDelete: SetNull)

  @@schema("aqua_db")
  @@index([chainId, sortOrder])
}

model PtLoadScenario {
  id              String   @id @default(uuid()) @db.Uuid
  chainId         String   @db.Uuid
  name            String   @db.VarChar(300)
  description     String?  @db.Text
  pattern         String   @db.VarChar(30)  // ramp | spike | soak | stress | step | custom
  peakVU          Int      @default(10)
  rampUpSec       Int      @default(30)
  steadyStateSec  Int      @default(60)
  rampDownSec     Int      @default(10)
  thinkTimeSec    Float    @default(1)
  pacingSec       Float    @default(0)
  timeoutMs       Int      @default(30000)
  maxErrorPct     Float    @default(10)
  slaThresholds   String?  @db.Text  // JSON: [{metric, operator, value, severity}]
  customRampSteps String?  @db.Text  // JSON: [{atSec, targetVU}] for custom pattern
  isDemo          Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  chain PtApiChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  runs  PtTestRun[]

  @@schema("aqua_db")
  @@index([chainId])
}

model PtTestRun {
  id            String    @id @default(uuid()) @db.Uuid
  scenarioId    String    @db.Uuid
  status        String    @db.VarChar(20) // queued | running | completed | failed | stopped
  startedAt     DateTime  @default(now()) @db.Timestamptz
  completedAt   DateTime? @db.Timestamptz
  totalRequests Int       @default(0)
  totalErrors   Int       @default(0)
  avgLatencyMs  Float     @default(0)
  p50LatencyMs  Float     @default(0)
  p95LatencyMs  Float     @default(0)
  p99LatencyMs  Float     @default(0)
  maxLatencyMs  Float     @default(0)
  peakTps       Float     @default(0)
  avgTps        Float     @default(0)
  errorRate     Float     @default(0)
  slaResults    String?   @db.Text  // JSON: [{metric, target, actual, passed}]
  aiAnalysis    String?   @db.Text  // AI-generated bottleneck analysis
  reportData    String?   @db.Text  // JSON: full report payload

  scenario PtLoadScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  metrics  PtTestMetric[]
  stepMetrics PtStepMetric[]

  @@schema("aqua_db")
  @@index([scenarioId])
  @@index([status])
  @@index([startedAt])
}

model PtTestMetric {
  id           String   @id @default(uuid()) @db.Uuid
  runId        String   @db.Uuid
  timestamp    DateTime @db.Timestamptz
  activeVU     Int
  requestCount Int
  errorCount   Int
  avgLatencyMs Float
  p95LatencyMs Float
  p99LatencyMs Float
  tps          Float
  bytesIn      BigInt   @default(0)
  bytesOut     BigInt   @default(0)

  run PtTestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([runId, timestamp])
}

model PtStepMetric {
  id           String @id @default(uuid()) @db.Uuid
  runId        String @db.Uuid
  stepName     String @db.VarChar(300)
  method       String @db.VarChar(10)
  url          String @db.VarChar(1000)
  totalCalls   Int    @default(0)
  totalErrors  Int    @default(0)
  avgLatencyMs Float  @default(0)
  p95LatencyMs Float  @default(0)
  p99LatencyMs Float  @default(0)
  minLatencyMs Float  @default(0)
  maxLatencyMs Float  @default(0)
  errorsByStatus String? @db.Text // JSON: {"404": 5, "500": 2}

  run PtTestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@schema("aqua_db")
  @@index([runId])
}
