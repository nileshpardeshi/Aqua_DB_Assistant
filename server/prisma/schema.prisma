generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE: Projects & Workspace
// ============================================================

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  dialect     String   // postgresql | mysql | oracle | sqlserver | snowflake | bigquery | mongodb | mariadb
  status      String   @default("active")
  schemas     String?  // JSON array of schema names, e.g. ["public", "auth", "billing"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  files              ProjectFile[]
  schemaSnapshots    SchemaSnapshot[]
  tables             TableMetadata[]
  savedQueries       SavedQuery[]
  queryExecutions    QueryExecution[]
  performanceRuns    PerformanceRun[]
  migrations         Migration[]
  dataLifecycleRules DataLifecycleRule[]
  aiConversations    AIConversation[]
  dbConnections      DatabaseConnection[]
  auditLogs          AuditLog[]
  columnMappings     ColumnMappingConfig[]
  dataSheetMappings  DataSheetMappingConfig[]
  savedDiagrams      SavedDiagram[]

  @@index([status])
  @@index([createdAt])
}

model ProjectFile {
  id         String   @id @default(uuid())
  projectId  String
  fileName   String
  filePath   String
  fileType   String
  fileSize   Int
  dialect    String?
  checksum   String
  uploadedAt DateTime @default(now())

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parseResult FileParseResult?

  @@index([projectId])
  @@index([fileType])
}

model FileParseResult {
  id             String    @id @default(uuid())
  fileId         String    @unique
  status         String    @default("pending")
  statementCount Int       @default(0)
  tableCount     Int       @default(0)
  errorCount     Int       @default(0)
  errors         String?
  parsedAt       DateTime?
  duration       Int?

  file ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

// ============================================================
// SCHEMA INTELLIGENCE
// ============================================================

model SchemaSnapshot {
  id           String   @id @default(uuid())
  projectId    String
  version      Int
  label        String?
  snapshotData String
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

model TableMetadata {
  id            String   @id @default(uuid())
  projectId     String
  schemaName    String   @default("public")
  tableName     String
  tableType     String   @default("table")
  description   String?
  estimatedRows BigInt?
  originalDDL   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns     ColumnMetadata[]
  indexes     IndexMetadata[]
  constraints ConstraintMetadata[]
  triggers    TriggerMetadata[]

  outgoingRelationships RelationshipMetadata[] @relation("SourceTable")
  incomingRelationships RelationshipMetadata[] @relation("TargetTable")

  @@unique([projectId, schemaName, tableName])
  @@index([projectId])
}

model ColumnMetadata {
  id                 String  @id @default(uuid())
  tableId            String
  columnName         String
  dataType           String
  normalizedType     String?
  ordinalPosition    Int
  isNullable         Boolean @default(true)
  isPrimaryKey       Boolean @default(false)
  isUnique           Boolean @default(false)
  defaultValue       String?
  characterMaxLength Int?
  numericPrecision   Int?
  numericScale       Int?
  description        String?
  sensitivityTag     String?

  table TableMetadata @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, columnName])
  @@index([tableId, ordinalPosition])
}

model IndexMetadata {
  id          String  @id @default(uuid())
  tableId     String
  indexName   String
  indexType   String
  isUnique    Boolean @default(false)
  isPrimary   Boolean @default(false)
  columns     String
  originalDDL String?

  table TableMetadata @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, indexName])
}

model ConstraintMetadata {
  id             String  @id @default(uuid())
  tableId        String
  constraintName String
  constraintType String
  definition     String?
  columns        String

  table TableMetadata @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, constraintName])
}

model RelationshipMetadata {
  id               String  @id @default(uuid())
  sourceTableId    String
  targetTableId    String
  relationshipType String
  sourceColumns    String
  targetColumns    String
  constraintName   String?
  isInferred       Boolean @default(false)
  onDelete         String?
  onUpdate         String?

  sourceTable TableMetadata @relation("SourceTable", fields: [sourceTableId], references: [id], onDelete: Cascade)
  targetTable TableMetadata @relation("TargetTable", fields: [targetTableId], references: [id], onDelete: Cascade)

  @@index([sourceTableId])
  @@index([targetTableId])
}

model TriggerMetadata {
  id          String   @id @default(uuid())
  tableId     String
  triggerName String
  timing      String   // BEFORE | AFTER | INSTEAD OF
  event       String   // INSERT | UPDATE | DELETE
  triggerBody String
  isEnabled   Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  table TableMetadata @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, triggerName])
  @@index([tableId])
}

// ============================================================
// QUERY INTELLIGENCE
// ============================================================

model SavedQuery {
  id          String   @id @default(uuid())
  projectId   String
  title       String
  description String?
  sql         String
  dialect     String
  category    String?
  isFavorite  Boolean  @default(false)
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions QueryExecution[]

  @@index([projectId])
}

model QueryExecution {
  id            String   @id @default(uuid())
  projectId     String
  savedQueryId  String?
  sql           String
  dialect       String
  status        String
  rowsAffected  Int?
  rowsReturned  Int?
  executionTime Int?
  resultPreview String?
  explainPlan   String?
  errorMessage  String?
  executedAt    DateTime @default(now())

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  savedQuery SavedQuery? @relation(fields: [savedQueryId], references: [id], onDelete: SetNull)

  @@index([projectId, executedAt])
}

// ============================================================
// PERFORMANCE LAB
// ============================================================

model PerformanceRun {
  id              String    @id @default(uuid())
  projectId       String
  runType         String
  status          String
  summary         String?
  findings        String?
  recommendations String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, startedAt])
}

// ============================================================
// MIGRATION STUDIO
// ============================================================

model Migration {
  id            String    @id @default(uuid())
  projectId     String
  version       String
  title         String
  description   String?
  upSQL         String
  downSQL       String?
  status        String    @default("draft")
  appliedAt     DateTime?
  sourceDialect String
  targetDialect String
  checksum      String
  dependsOn     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId, status])
}

model ColumnMappingConfig {
  id              String   @id @default(uuid())
  projectId       String
  name            String
  sourceTableName String
  targetTableName String
  sourceDialect   String
  targetDialect   String
  mappings        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model DataSheetMappingConfig {
  id              String   @id @default(uuid())
  projectId       String
  name            String
  sourceTableName String
  csvFileName     String
  mappings        String   // JSON: DataSheetMapping[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// DIAGRAM STUDIO
// ============================================================

model SavedDiagram {
  id            String   @id @default(uuid())
  projectId     String
  name          String
  description   String?
  diagramType   String   // er-full | er-compact | dependency-graph | schema-group
  includedTables String? // JSON: string[] of table IDs (null = all tables)
  nodePositions  String? // JSON: Record<string, {x:number,y:number}>
  layoutDirection String @default("TB") // TB | LR
  showColumns    Boolean @default(true)
  showLabels     Boolean @default(true)
  colorBySchema  Boolean @default(false)
  annotations    String? // JSON: Array<{id,x,y,text,color}>
  isDefault      Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// DATA LIFECYCLE MANAGEMENT
// ============================================================

model DataLifecycleRule {
  id            String   @id @default(uuid())
  projectId     String
  ruleName      String
  ruleType      String
  targetTable   String
  targetColumns String?
  configuration String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, ruleType])
}

// ============================================================
// AI CONVERSATIONS
// ============================================================

model AIConversation {
  id        String   @id @default(uuid())
  projectId String
  title     String
  context   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([projectId, context])
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String
  metadata       String?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ============================================================
// DATABASE CONNECTIONS
// ============================================================

model DatabaseConnection {
  id                String    @id @default(uuid())
  projectId         String
  name              String
  dialect           String
  host              String
  port              Int
  database          String
  username          String
  passwordEncrypted String
  sslEnabled        Boolean   @default(false)
  sslConfig         String?
  isActive          Boolean   @default(true)
  lastTestedAt      DateTime?
  createdAt         DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// SETTINGS & SECURITY
// ============================================================

model AppSettings {
  id    String @id @default("singleton")
  key   String @unique
  value String
}

model AIProviderConfig {
  id              String   @id @default(uuid())
  provider        String
  apiKeyEncrypted String?
  baseUrl         String?
  model           String
  isDefault       Boolean  @default(false)
  maxTokens       Int      @default(4096)
  temperature     Float    @default(0.3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, model])
}

model AuditLog {
  id        String   @id @default(uuid())
  projectId String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([action, createdAt])
}
