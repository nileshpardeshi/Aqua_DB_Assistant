# ============================================
# Aqua DB Copilot — Environment Configuration
# ============================================

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://user:password@localhost:5432/aqua_db?schema=public

# Encryption Key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-character-minimum-secret-key-change-this

# AI Provider (anthropic | openai | ollama)
DEFAULT_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# OLLAMA_BASE_URL=http://localhost:11434

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Logging
LOG_LEVEL=info
